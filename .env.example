SECMIND_ENV=development
SECMIND_DEMO_MODE=true
SECMIND_DATABASE_URL=sqlite:///./data/secmind.db
SECMIND_INPUT_ROOT=./data/inputs
SECMIND_RUN_ROOT=./data/runs
SECMIND_UPLOAD_ROOT=./data/uploads
SECMIND_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SECMIND_QWEN_API_KEY=
SECMIND_PLANNER_MODEL=qwen-plus
SECMIND_WORKER_MODEL=qwen-turbo
SECMIND_FALLBACK_MODEL=qwen-max
SECMIND_EMBEDDING_MODEL=text-embedding-v3
SECMIND_QDRANT_URL=http://qdrant:6333
SECMIND_QDRANT_COLLECTION=secmind_knowledge
SECMIND_MAX_STEPS=12
SECMIND_MAX_TOOL_CALLS=12
SECMIND_MAX_MODEL_CALLS=20
SECMIND_MAX_RUNTIME_SECONDS=600
SECMIND_MAX_UPLOAD_BYTES=52428800
SECMIND_MAX_EXTRACTED_BYTES=209715200
